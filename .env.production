# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# turbinesuasredes.com.br
# ============================================

# APP CONFIGURATION
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://turbinesuasredes.com.br
NEXT_PUBLIC_APP_NAME=Caminho Digital

# AUTHENTICATION
NEXTAUTH_URL=https://turbinesuasredes.com.br
NEXTAUTH_SECRET=your-production-secret-key-change-this
AUTH_REDIRECT_CALLBACK=https://turbinesuasredes.com.br/auth/callback

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_AUTH_REDIRECT_TO=https://turbinesuasredes.com.br/auth/callback
SUPABASE_AUTH_EXTERNAL_REDIRECT_URLS=https://turbinesuasredes.com.br/auth/callback,https://www.turbinesuasredes.com.br/auth/callback

# DATABASE
DATABASE_URL=your_production_database_url

# OAUTH PROVIDERS
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://turbinesuasredes.com.br/auth/callback/google

META_CLIENT_ID=your_meta_client_id
META_CLIENT_SECRET=your_meta_client_secret
META_REDIRECT_URI=https://turbinesuasredes.com.br/auth/callback/meta

# CLAUDE API
ANTHROPIC_API_KEY=your_anthropic_api_key

# PAYMENTS
STRIPE_SECRET_KEY=sk_live_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# TICTO (Payments)
TICTO_API_KEY=your_ticto_api_key
TICTO_WEBHOOK_SECRET=your_ticto_webhook_secret

# API ENDPOINTS
API_BASE_URL=https://turbinesuasredes.com.br/api
NEXT_PUBLIC_API_URL=https://turbinesuasredes.com.br/api

# SECURITY
CORS_ORIGIN=https://turbinesuasredes.com.br
ALLOWED_ORIGINS=https://turbinesuasredes.com.br,https://www.turbinesuasredes.com.br

# ANALYTICS
NEXT_PUBLIC_ANALYTICS_ID=your_ga4_id

# LOGGING
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn
